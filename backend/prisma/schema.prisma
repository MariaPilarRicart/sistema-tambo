generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RolUsuario {
  ADMIN
  EMPLEADO
}

enum CategoriaAnimal {
  GUACHERA
  ESCUELITA
  TERNERA
  VAQUILLONA
  VACA_PRODUCCION
  VACA_SECA
  PREPARTO
  TORO
  BAJA
}

enum EstadoReproductivo {
  NO_APLICA
  VACIA
  INSEMINADA
  PRENADA
  SECA
  RECUPERACION
}

enum EstadoAnimal {
  ACTIVO
  VENDIDO
  MUERTO
  ROBADO
  TRASLADADO
  OTRO
}

enum TipoEvento {
  CELO
  INSEMINACION
  TACTO
  SECADO
  PARTO
  ABORTO
  CLINICO
  VACUNACION
  CAMBIO_LOTE
  VENTA
  MUERTE
}

enum TipoTarea {
  TACTO
  SECADO
  PARTO
  ALTA_POST_PARTO
  VACUNACION
  CONTROL_CLINICO
}

enum EstadoTarea {
  PENDIENTE
  REALIZADA
  CANCELADA
}

enum TipoReglaSanitaria {
  VACUNA
  ANALISIS
}

enum TipoMovimientoStockAlimentacion {
  ENTRADA
  CONSUMO
  CONSUMO_ALIMENTACION
  BAJA_MANUAL
  AJUSTE
  BAJA
  MODIFICACION
}

enum TipoAlimento {
  SILO
  BALANCEADO
  FIBRA
  SUPLEMENTO
  SALES
  OTRO
}

enum UnidadAlimento {
  KG
  ROLLO
  UNIDAD
}

enum TipoCalculoAlimentacion {
  KG_POR_ANIMAL_DIA
  ROLLOS_POR_GRUPO_DURACION
  OBLIGATORIO_SIN_CANTIDAD
}

enum TurnoOrdene {
  MANANA
  TARDE
  NOCHE
}

enum MotivoDescarteLeche {
  MASTITIS
  ANTIBIOTICO
  ANTIBIOTICOS
  CALOSTRO
  MALA_CALIDAD
  CONTAMINACION
  PROBLEMA_SANITARIO
  TEMPERATURA_FUERA_DE_RANGO
  OTRO
}

enum EstadoLoteLeche {
  DISPONIBLE
  VENDIDO
  VENCIDO
  INACTIVO
}

model Usuario {
  id           Int        @id @default(autoincrement())
  nombre       String
  username     String     @unique
  email        String?    @unique
  passwordHash String
  rol          RolUsuario
  activo       Boolean    @default(true)
  debeCambiarPassword Boolean @default(false)
  fotoPerfil   String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  eventos               Evento[]
  registrosAlimentacion RegistroAlimentacion[]
  movimientosStock      MovimientoStockAlimentacion[]
  producciones          ProduccionAnimal[]
  ventas                Venta[]
  tareasAgenda          AgendaTarea[]
  notificacionesAtendidas NotificacionUsuarioAtendida[]

  @@map("usuarios")
}

model NotificacionUsuarioAtendida {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  clave     String
  firma     String
  estado    String   @default("ATENDIDA")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, clave, firma])
  @@index([usuarioId])
  @@index([clave])
  @@map("notificaciones_usuario_atendidas")
}

model ReglaSanitaria {
  id                Int               @id @default(autoincrement())
  nombre            String
  codigo            String            @unique
  tipo              TipoReglaSanitaria
  mesFijo           Int?
  frecuenciaMeses   Int               @default(12)
  anticipacionMeses Int               @default(1)
  activo            Boolean           @default(true)
  observaciones     String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([activo])
  @@index([tipo])
  @@map("reglas_sanitarias")
}

model Lote {
  id          Int      @id @default(autoincrement())
  nombre      String   @unique
  descripcion String?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  animales              Animal[]
  registrosAlimentacion RegistroAlimentacion[]
  tareasSanitarias      AgendaTarea[] @relation("AlcanceLoteSanitario")

  @@map("lotes")
}

model Racion {
  id          Int      @id @default(autoincrement())
  nombre      String   @unique
  descripcion String?
  categoriaAnimal CategoriaAnimal?
  activa      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  registrosAlimentacion RegistroAlimentacion[]

  @@map("raciones")
}

model InsumoAlimentacion {
  id           Int      @id @default(autoincrement())
  nombre       String   @unique
  descripcion  String?
  tipoAlimento TipoAlimento @default(OTRO)
  unidadMedida String
  stockActual  Float    @default(0)
  stockMinimo  Float    @default(0)
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  movimientos MovimientoStockAlimentacion[]
  detallesAlimentacion DetalleAlimentacion[]
  detallesReglasAlimentacion DetalleReglaAlimentacion[]

  @@index([tipoAlimento])
  @@map("insumos_alimentacion")
}

model ReglaAlimentacion {
  id              Int      @id @default(autoincrement())
  nombre          String
  categoriaAnimal CategoriaAnimal
  activo          Boolean  @default(true)
  observaciones   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  detalles DetalleReglaAlimentacion[]

  @@unique([categoriaAnimal, nombre])
  @@index([categoriaAnimal])
  @@index([activo])
  @@map("reglas_alimentacion")
}

model DetalleReglaAlimentacion {
  id                  Int                     @id @default(autoincrement())
  reglaAlimentacionId Int
  alimentoId          Int
  tipoCalculo         TipoCalculoAlimentacion
  unidad              UnidadAlimento
  cantidadMinima      Float?
  cantidadMaxima      Float?
  animalesBase        Int?
  rollosBase          Float?
  duracionDias        Int?
  obligatorio         Boolean                 @default(false)
  observaciones       String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  regla    ReglaAlimentacion @relation(fields: [reglaAlimentacionId], references: [id], onDelete: Cascade)
  alimento InsumoAlimentacion @relation(fields: [alimentoId], references: [id], onDelete: Restrict)

  @@unique([reglaAlimentacionId, alimentoId])
  @@index([reglaAlimentacionId])
  @@index([alimentoId])
  @@map("detalles_reglas_alimentacion")
}

model LoteLeche {
  id                       Int              @id @default(autoincrement())
  codigo                   String           @unique
  descripcion              String?
  fechaProduccion          DateTime
  fechaVencimiento         DateTime
  fechaVenta               DateTime?
  estado                   EstadoLoteLeche  @default(DISPONIBLE)
  litrosTotales            Decimal          @default(0) @db.Decimal(10, 2)
  litrosDescartados        Decimal          @default(0) @db.Decimal(10, 2)
  litrosNetos              Decimal          @default(0) @db.Decimal(10, 2)
  motivoDescarte           MotivoDescarteLeche?
  observacionDescarte      String?
  grasa                    Decimal?         @db.Decimal(5, 2)
  proteina                 Decimal?         @db.Decimal(5, 2)
  recuentoBacteriano       Int?
  recuentoCelulasSomaticas Int?
  temperatura              Decimal?         @db.Decimal(5, 2)
  observacionesCalidad     String?
  producciones             ProduccionAnimal[]
  ventaDetalles            VentaDetalle[]
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  @@index([estado])
  @@index([fechaProduccion])
  @@map("lotes_leche")
}

model Cliente {
  id          Int      @id @default(autoincrement())
  cuit        String   @unique
  razonSocial String
  direccion   String?
  telefono    String?
  email       String?
  fechaAlta   DateTime @default(now())
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ventas Venta[]

  @@index([activo])
  @@map("clientes")
}

model Venta {
  id            Int      @id @default(autoincrement())
  clienteId     Int
  numeroFactura String   @unique
  fechaVenta    DateTime
  precioPorLitro Decimal  @db.Decimal(12, 2)
  totalLitros   Decimal  @db.Decimal(10, 2)
  precioTotal   Decimal  @db.Decimal(12, 2)
  observaciones String?
  usuarioId     Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cliente  Cliente        @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  usuario  Usuario        @relation(fields: [usuarioId], references: [id], onDelete: Restrict)
  detalles VentaDetalle[]

  @@index([clienteId])
  @@index([usuarioId])
  @@index([fechaVenta])
  @@map("ventas")
}

model VentaDetalle {
  id              Int     @id @default(autoincrement())
  ventaId         Int
  loteLecheId     Int
  litrosVendidos  Decimal @db.Decimal(10, 2)
  precioUnitario  Decimal @db.Decimal(12, 2)
  subtotal        Decimal @db.Decimal(12, 2)

  venta     Venta     @relation(fields: [ventaId], references: [id], onDelete: Restrict)
  loteLeche LoteLeche @relation(fields: [loteLecheId], references: [id], onDelete: Restrict)

  @@index([ventaId])
  @@index([loteLecheId])
  @@map("venta_detalles")
}

model MovimientoStockAlimentacion {
  id             Int                             @id @default(autoincrement())
  insumoId       Int
  alimentacionId Int?
  tipoMovimiento TipoMovimientoStockAlimentacion
  fecha          DateTime
  cantidad       Float
  observaciones  String?
  usuarioId      Int?
  createdAt      DateTime                        @default(now())
  updatedAt      DateTime                        @updatedAt

  insumo       InsumoAlimentacion   @relation(fields: [insumoId], references: [id], onDelete: Restrict)
  alimentacion RegistroAlimentacion? @relation(fields: [alimentacionId], references: [id], onDelete: SetNull)
  usuario      Usuario?             @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([insumoId])
  @@index([alimentacionId])
  @@index([usuarioId])
  @@index([tipoMovimiento])
  @@index([fecha])
  @@map("movimientos_stock_alimentacion")
}

model RegistroAlimentacion {
  id            Int      @id @default(autoincrement())
  fecha         DateTime
  loteId        Int?
  categoriaAnimal CategoriaAnimal
  cantidadAnimales Int?
  racionId      Int?
  cantidadKg    Float
  observaciones String?
  usuarioId     Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lote    Lote?    @relation(fields: [loteId], references: [id], onDelete: Restrict)
  racion  Racion?  @relation(fields: [racionId], references: [id], onDelete: Restrict)
  usuario Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  detalles DetalleAlimentacion[]
  movimientosStock MovimientoStockAlimentacion[]

  @@index([fecha])
  @@index([loteId])
  @@index([categoriaAnimal])
  @@index([racionId])
  @@index([usuarioId])
  @@unique([loteId, fecha])
  @@map("registros_alimentacion")
}

model DetalleAlimentacion {
  id             Int      @id @default(autoincrement())
  alimentacionId Int
  insumoId       Int
  cantidad       Float
  unidad         String
  cantidadSugeridaMinima Float?
  cantidadSugeridaMaxima Float?
  observaciones  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  alimentacion RegistroAlimentacion @relation(fields: [alimentacionId], references: [id], onDelete: Cascade)
  insumo       InsumoAlimentacion   @relation(fields: [insumoId], references: [id], onDelete: Restrict)

  @@index([alimentacionId])
  @@index([insumoId])
  @@map("detalles_alimentacion")
}

model Animal {
  id                 Int                @id @default(autoincrement())
  caravana           String             @unique
  nombre             String?
  fechaNacimiento    DateTime
  raza               String?
  categoriaAnimal    CategoriaAnimal @map("categoria")
  estadoReproductivo EstadoReproductivo @default(VACIA)
  estadoAnimal       EstadoAnimal       @default(ACTIVO)
  activo             Boolean            @default(true)
  fechaBaja          DateTime?
  observacionesBaja  String?
  loteId             Int
  madreId            Int?
  padreNombre        String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  lote    Lote          @relation(fields: [loteId], references: [id], onDelete: Restrict)
  madre   Animal?       @relation("MadreHijos", fields: [madreId], references: [id], onDelete: Restrict)
  hijos   Animal[]      @relation("MadreHijos")
  eventos Evento[]
  tareas  AgendaTarea[]
  producciones ProduccionAnimal[]

  @@index([loteId])
  @@index([madreId])
  @@index([estadoAnimal])
  @@index([estadoReproductivo])
  @@map("animales")
}

model Evento {
  id            Int        @id @default(autoincrement())
  tipo          TipoEvento
  fecha         DateTime   @default(now())
  observaciones String?
  animalId      Int
  usuarioId     Int?
  datosJson     Json?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  animal         Animal        @relation(fields: [animalId], references: [id], onDelete: Restrict)
  usuario        Usuario?      @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  tareasCreadas  AgendaTarea[] @relation("EventoOrigenTarea")
  tareasCerradas AgendaTarea[] @relation("EventoCierreTarea")

  @@index([animalId])
  @@index([usuarioId])
  @@index([tipo])
  @@index([fecha])
  @@map("eventos")
}

model AgendaTarea {
  id               Int         @id @default(autoincrement())
  tipo             TipoTarea
  fechaProgramada  DateTime
  fechaObjetivo    DateTime?
  fechaRealizacion DateTime?
  estado           EstadoTarea @default(PENDIENTE)
  descripcion      String?
  animalId         Int
  usuarioId        Int?
  eventoOrigenId   Int?
  eventoCierreId   Int?
  tipoSanitario    String?
  alcanceTipo      String?
  alcanceLoteId    Int?
  alcanceCategoria CategoriaAnimal?
  grupoSanitarioId String?
  cantidadAnimalesAlcanzados Int?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  animal       Animal  @relation(fields: [animalId], references: [id], onDelete: Restrict)
  usuario      Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  alcanceLote  Lote?   @relation("AlcanceLoteSanitario", fields: [alcanceLoteId], references: [id], onDelete: SetNull)
  eventoOrigen Evento? @relation("EventoOrigenTarea", fields: [eventoOrigenId], references: [id], onDelete: SetNull)
  eventoCierre Evento? @relation("EventoCierreTarea", fields: [eventoCierreId], references: [id], onDelete: SetNull)

  @@index([animalId])
  @@index([usuarioId])
  @@index([alcanceLoteId])
  @@index([eventoOrigenId])
  @@index([eventoCierreId])
  @@index([estado])
  @@index([tipo])
  @@index([tipoSanitario])
  @@index([grupoSanitarioId])
  @@index([fechaProgramada])
  @@index([fechaObjetivo])
  @@map("agenda_tareas")
}

model ProduccionAnimal {
  id                  Int                  @id @default(autoincrement())
  animalId            Int
  loteLecheId         Int
  usuarioId           Int
  fechaHora           DateTime
  turno               TurnoOrdene
  litrosProducidos    Decimal              @db.Decimal(10, 2)
  litrosDescartados   Decimal              @default(0) @db.Decimal(10, 2)
  motivoDescarte      MotivoDescarteLeche?
  observacionDescarte String?
  activo              Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  animal    Animal    @relation(fields: [animalId], references: [id], onDelete: Restrict)
  loteLeche LoteLeche @relation(fields: [loteLecheId], references: [id], onDelete: Restrict)
  usuario   Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Restrict)

  @@unique([animalId, fechaHora, turno])
  @@index([animalId])
  @@index([loteLecheId])
  @@index([fechaHora])
  @@index([turno])
  @@index([usuarioId])
  @@index([activo])
  @@map("producciones_animales")
}
